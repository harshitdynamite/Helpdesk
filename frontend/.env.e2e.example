# E2E test-database connection — copy this file to .env.e2e and adjust.
#   cp .env.e2e.example .env.e2e
#
# These configure the dedicated `helpdesk_e2e` Postgres database that Playwright's
# orchestration (playwright.config.ts) migrates and runs the API against. The real
# .env.e2e is gitignored; this .example template is committed.
#
# Set E2E_DB_PASSWORD to match your local Postgres role (the project's dev password is 1234).

E2E_DB_HOST=localhost
E2E_DB_PORT=5432
E2E_DB_NAME=helpdesk_e2e
E2E_DB_USER=postgres
E2E_DB_PASSWORD=postgres
